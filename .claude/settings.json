{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/check-versioncode.sh\"",
            "timeout": 15,
            "statusMessage": "Checking mobile versionCode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/toil-trigger.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-behind-origin.sh\"",
            "timeout": 20,
            "statusMessage": "Checking if repo is behind origin..."
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "swarm": {
      "source": {
        "source": "github",
        "repo": "evanda/agent-swarm",
        "ref": "v0.1.1"
      }
    }
  },
  "enabledPlugins": {
    "swarm@swarm": true
  }
}
