{
  "name": "cmc",
  "private": true,
  "version": "0.0.0",
  "description": "Campus Facilities Maintenance System — CMMS monorepo (web + mobile + loader + shared)",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "verify": "turbo run lint typecheck test",
    "check-versions": "node scripts/check-version-sync.js",
    "triage:fetch": "node .agents/skills/feedback-rationalizer/scripts/fetch_issues.js",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff --linked",
    "db:seed": "tsx scripts/reset-seed.ts",
    "map:place": "node map-data/place-server.mjs",
    "map:areas": "node map-data/place-server.mjs",
    "facility:export": "node scripts/facility-export.mjs",
    "facility:import": "node scripts/facility-import.mjs",
    "screenshots": "node scripts/screenshot.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@sparticuz/chromium": "^131.0.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.3.3",
    "puppeteer-core": "^23.0.0",
    "tsx": "^4.19.2",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.12.2"
  }
}
