# ──────────────────────────────────────────────────────────────────────────
# CMC environment — copy to .env and fill in. NEVER commit a real .env.
# Single-tenant per deployment: each church has its own Supabase project.
# ──────────────────────────────────────────────────────────────────────────

# Web app (apps/web) — Vite exposes only VITE_*-prefixed vars to the client.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side / CLI tooling (migrations, seed scripts). Keep OUT of the client.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local development against the Supabase CLI stack (supabase start) typically:
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=<anon key printed by `supabase start`>
