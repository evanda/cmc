# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.turbo/
.vercel/
.expo/

# Supabase local stack
supabase/.branches/
supabase/.temp/

# Env / secrets
.env
.env.*
!.env.example

# Triage scratch output
feedback_issues.json

# Generated screenshots (regenerate via `pnpm screenshots`)
screenshots/


# Placement-tool save backups (place-server.mjs writes pois.geojson.bak)
map-data/facilities/*/*.bak

# Claude Code local overrides
.claude/settings.local.json

# Swarm runtime event log (config.json is tracked; the log is not)
.swarm/run-log.jsonl

# Tool/installer backups (e.g. agent-swarm writes <file>.<timestamp>.bak)
*.bak

# OS
.DS_Store
